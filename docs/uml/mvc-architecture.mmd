---
title: TudouHeroTest · MVC + Infra Architecture
---
classDiagram
    %% ============================
    %% Infra (Infrastructure) Layer
    %% ============================

    %% Singleton Bases
    class BaseMgr {
        <<abstract>>
        +Instance T
    }
    class BaseMgrMono {
        <<abstract>>
        +Instance T
        #Awake()
    }

    %% Core Services
    class EventCenter {
        +AddEventListener(type, action)
        +RemoveEventListener(type, action)
        +EventTrigger(type, info)
    }
    class ConfigMgr {
        +LoadList(key) List
    }
    class UIMgr {
        +ShowPanel(name) BasePanel
        +HidePanel(name)
    }
    class PoolMgr {
        +GetObj(name, callback)
        +PushObj(name, obj)
    }
    class ResourceMgr {
        +LoadAsync(name, callback)
    }
    class AudioMgr {
        +PlayBGM(name)
        +PlaySound(name)
    }
    class MonoMgr {
        +AddUpdateListener(action)
        +StartCoroutine(routine)
    }

    BaseMgr <|-- EventCenter
    BaseMgr <|-- ConfigMgr
    BaseMgr <|-- UIMgr
    BaseMgrMono <|-- PoolMgr
    BaseMgrMono <|-- ResourceMgr
    BaseMgrMono <|-- AudioMgr
    BaseMgrMono <|-- MonoMgr

    %% ============================
    %% MVC · Model Layer
    %% ============================
    class GameManager {
        +hp int
        +money int
        +exp int
        +waveIndex int
        +selectedRole RoleData
        +selectedWeapon WeaponData
        +selectedDifficulty DifficultyData
        +ResetGameState()
    }
    class RoleData {
        +id int
        +name string
        +hp int
        +speed float
    }
    class WeaponData {
        +id int
        +name string
        +damage int
        +attackSpeed float
    }
    class EnemyData {
        +id int
        +hp int
        +speed float
        +damage int
    }
    class DifficultyData {
        +levelName string
    }
    class LevelData {
        +waveIndex int
    }
    class PlayerModel {
        +hp int
        +money int
    }

    BaseMgrMono <|-- GameManager
    GameManager *-- RoleData
    GameManager *-- WeaponData
    GameManager *-- DifficultyData
    ConfigMgr ..> RoleData : loads
    ConfigMgr ..> WeaponData : loads
    ConfigMgr ..> EnemyData : loads
    ConfigMgr ..> DifficultyData : loads
    ConfigMgr ..> LevelData : loads

    %% ============================
    %% MVC · View Layer
    %% ============================
    class BasePanel {
        <<abstract>>
        +ShowPanel()
        +HidePanel()
        #Init()
    }
    class BeginScenePanel
    class GamePanel {
        +RenewHp(hp)
        +RenewMoney(money)
        +RenewWave(wave)
    }
    class ShopPanel
    class RoleSelectPanel
    class WeaponSelectPanel
    class DifficultySelectPanel
    class FailPanel
    class SuccessPanel

    BasePanel <|-- BeginScenePanel
    BasePanel <|-- GamePanel
    BasePanel <|-- ShopPanel
    BasePanel <|-- RoleSelectPanel
    BasePanel <|-- WeaponSelectPanel
    BasePanel <|-- DifficultySelectPanel
    BasePanel <|-- FailPanel
    BasePanel <|-- SuccessPanel
    UIMgr ..> BasePanel : manages

    %% ============================
    %% MVC · Controller Layer
    %% ============================

    %% State Pattern
    class ISceneState {
        <<abstract>>
        +StateStart()
        +StateEnd()
    }
    class SceneStateController {
        +SetState(state)
    }
    class StartScene
    class SelectSecene
    class GameScene
    class ShopScene

    ISceneState <|-- StartScene
    ISceneState <|-- SelectSecene
    ISceneState <|-- GameScene
    ISceneState <|-- ShopScene
    SceneStateController o-- ISceneState : currentState

    class LevelControl {
        +StartWave()
        +SpawnEnemy()
        +BadGame()
        +GoodGame()
    }
    class Player {
        +hp int
        +Injured(damage)
        +Dead()
    }

    BaseMgrMono <|-- LevelControl
    BaseMgrMono <|-- Player
    GameManager --> SceneStateController : drives
    GameManager ..> EventCenter : listen/trigger
    LevelControl ..> EventCenter : triggers
    Player ..> EventCenter : triggers
    BeginScenePanel ..> EventCenter : triggers
    ShopPanel ..> EventCenter : triggers
    EventCenter ..> GamePanel : callback
    EventCenter ..> LevelControl : callback
    EventCenter ..> GameManager : callback

    %% ============================
    %% Game Objects Layer
    %% ============================
    class EnemyBase {
        <<abstract>>
        +hp int
        +speed float
        +damage int
        +Attack()
        +Dead()
    }
    class Enemy1
    class Enemy2
    class Enemy3
    class Enemy4
    class Enemy5

    class WeaponBase {
        <<abstract>>
        +damage int
        +attackSpeed float
        +Attack()
    }
    class WeaponShort
    class WeaponLong
    class FistWeapon
    class PistolWeapon
    class CrossbowWeapon
    class BranchWeapon
    class MedicalGunWeapon
    class WeaponSlot

    class Bullet {
        <<abstract>>
        +speed float
        +damage int
    }
    class ArrowBullet
    class PistolBullet
    class EnemyBullet
    class MedicalBullet

    EnemyBase <|-- Enemy1
    EnemyBase <|-- Enemy2
    EnemyBase <|-- Enemy3
    EnemyBase <|-- Enemy4
    EnemyBase <|-- Enemy5

    WeaponBase <|-- WeaponShort
    WeaponBase <|-- WeaponLong
    WeaponShort <|-- FistWeapon
    WeaponLong <|-- PistolWeapon
    WeaponLong <|-- CrossbowWeapon
    WeaponLong <|-- BranchWeapon
    WeaponLong <|-- MedicalGunWeapon
    WeaponSlot --> WeaponBase : holds

    Bullet <|-- ArrowBullet
    Bullet <|-- PistolBullet
    Bullet <|-- EnemyBullet
    Bullet <|-- MedicalBullet

    EnemyBase ..> EventCenter : triggers
    EnemyBase ..> PoolMgr : returns self
    WeaponBase ..> PoolMgr : spawns Bullet
