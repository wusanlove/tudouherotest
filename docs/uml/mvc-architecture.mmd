    %% MVC · Model Layer
    %% ============================
    class GameManager {
        <<Controller + Model Hub>>
        +currentRoleData RoleData
        +currentWeapons List
        +currentDifficulty DifficultyData
        +hp int
        +money int
        +exp int
        +waveIndex int
        +ResetGameState()
    }
    class RoleData {
        +id int
        +name string
        +hp int
        +speed float
    }
    class WeaponData {
        +id int
        +name string
        +damage int
        +attackSpeed float
    }
    class EnemyData {
        +id int
        +hp int
        +speed float
        +damage int
    }
    class DifficultyData {
        +levelName string
    }
    class LevelData {
        +waveIndex int
        +enemies List
    }
    class PlayerModel {
        +hp int
        +money int
    }

    BaseMgrMono <|-- GameManager
    GameManager *-- RoleData
    GameManager *-- WeaponData
    GameManager *-- DifficultyData
    ConfigMgr ..> RoleData : loads
    ConfigMgr ..> WeaponData : loads
    ConfigMgr ..> EnemyData : loads
    ConfigMgr ..> DifficultyData : loads
    ConfigMgr ..> LevelData : loads

