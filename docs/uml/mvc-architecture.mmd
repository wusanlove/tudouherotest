    class ShopPanel
    class RoleSelectPanel
    class WeaponSelectPanel
    class DifficultySelectPanel
    class FailPanel
    class SuccessPanel

    BasePanel <|-- BeginScenePanel
    BaseMgrMono <|-- GamePanel
    BaseMgrMono <|-- ShopPanel
    BaseMgrMono <|-- RoleSelectPanel
    BaseMgrMono <|-- WeaponSelectPanel
    BaseMgrMono <|-- DifficultySelectPanel
    BaseMgrMono <|-- FailPanel
    BaseMgrMono <|-- SuccessPanel
    UIMgr ..> BasePanel : manages

    %% ============================
    %% MVC · Controller Layer
    %% ============================

    %% 【状态模式 State Pattern】SceneStateController + ISceneState + 四个场景状态
    class ISceneState {
        <<State · abstract>>
        #controller SceneStateController
        +StateStart()
        +StateEnd()
    }
    class SceneStateController {
        <<Context · State Pattern>>
        -currentState ISceneState
        +SetState(state, isLoadScene)
        +StateUpdate()
    }
    class StartScene {
        +SceneName = 01-MainMenu
    }
    class SelectSecene {
        +SceneName = 02-LevelSelect
    }
    class GameScene {
        +SceneName = 03-GamePlay
    }
    class ShopScene {
        +SceneName = 04-Shop
    }
    note for SceneStateController "【状态模式 State Pattern】\nContext 持有当前 ISceneState\n调用 SetState() 完成状态切换\n并异步加载对应场景"
    note for ISceneState "【状态模式 State Pattern】\n抽象状态基类\n每个 Scene 状态封装\nStateStart/StateEnd 行为"

    ISceneState <|-- StartScene
    ISceneState <|-- SelectSecene
    ISceneState <|-- GameScene
    ISceneState <|-- ShopScene
    SceneStateController o-- ISceneState : currentState

    class LevelControl {
        +StartWave()
        +SpawnEnemy()
        +BadGame()
        +GoodGame()
    }
    class Player {
        +hp int
        +Injured(damage)
        +Dead()
    }

    BaseMgrMono <|-- LevelControl
    BaseMgrMono <|-- Player

    %% GameManager drives SceneStateController and listens to EventCenter
    GameManager --> SceneStateController : drives (Update→StateUpdate)
    GameManager --> ConfigMgr : reads config on Awake
    GameManager ..> EventCenter : subscribe Scene_To*\ntrigger GameState events

    LevelControl ..> EventCenter : trigger Wave_*/Scene_To*
    Player ..> EventCenter : trigger Player_HpChanged\nPlayer_Dead

    BeginScenePanel ..> EventCenter : trigger Scene_ToLevelSelect
    ShopPanel ..> EventCenter : trigger Scene_ToGamePlay\nScene_ToMainMenu
    RoleSelectPanel ..> EventCenter : trigger role selected
    WeaponSelectPanel ..> EventCenter : trigger weapon selected
    DifficultySelectPanel ..> EventCenter : trigger Scene_ToGamePlay

    EventCenter ..> GamePanel : callback RenewHp/Money/Wave
    EventCenter ..> GameManager : callback scene transitions
    EventCenter ..> AudioMgr : dispatch Audio_* events

