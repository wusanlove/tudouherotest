---
title: TudouHeroTest · MVC + Infra Architecture
---
classDiagram
    direction TB

    %% ============================
    %% Infra (Infrastructure) Layer
    %% ============================
    %% 【单例模式 Singleton】BaseMgr<T> / BaseMgrMono<T> 作为单例基类
    class BaseMgr {
        <<abstract · Singleton Base>>
        +Instance T$
    }
    class BaseMgrMono {
        <<abstract · Singleton Base>>
        +Instance T$
        #Awake()
    }
    note for BaseMgr "【单例模式 Singleton】\n纯 C# 双重检查锁单例基类\n所有纯逻辑 Manager 继承此类"
    note for BaseMgrMono "【单例模式 Singleton】\nMonoBehaviour 单例基类\n(Unity 主线程，不可 new)"

    %% 【事件中心 / 观察者模式 Observer】
    class EventCenter {
        <<Observer · EventBus>>
        +AddEventListener(type, action)
        +RemoveEventListener(type, action)
        +EventTrigger(type, info)
        +ClearEvent(type)
    }
    class E_EventType {
        <<enum>>
        BeginScene_btn_start
        Scene_ToLevelSelect
        Scene_ToGamePlay
        Scene_ToShop
        Scene_ToMainMenu
        Player_HpChanged
        Player_Dead
        Wave_Started
        Wave_Ended
        Wave_AllCleared
        Audio_PlayBgm
        Audio_PlaySfx
        Audio_StopBgm
        Audio_SetVolume
    }
    note for EventCenter "【观察者模式 Observer / EventBus】\n类型安全的发布-订阅事件总线\n用 E_EventType 枚举作为 key\n解耦各子系统，禁止直接跨层引用"

    %% 【外观模式 Facade / 服务管理器集合】各 Mgr 作为系统服务统一入口
    class ConfigMgr {
        <<Facade · Service>>
        +LoadList(key) List
    }
    class UIMgr {
        <<Facade · Service>>
        +ShowPanel(name) BasePanel
        +HidePanel(name)
    }
    class PoolMgr {
        <<Facade · Service>>
        +GetObj(name, callback)
        +PushObj(name, obj)
    }
    class ResMgr {
        <<Facade · Service>>
        +Load(name) T
        +LoadAsync(name, callback)
    }
    class AudioMgr {
        <<Facade · Service>>
        +PlayBgm(id)
        +PlaySfx(id)
        +StopBgm()
        +SetVolume(master,bgm,sfx,ui)
    }
    %% 【生命周期代理 Proxy/Adapter】MonoMgr 为纯 C# 管理器提供 Update/协程
    class MonoMgr {
        <<Proxy · Lifecycle Adapter>>
        +AddUpdateListener(action)
        +StartCoroutine(routine)
    }
    note for MonoMgr "【生命周期代理 Proxy/Adapter】\n自身为 MonoBehaviour 单例\n为纯 C# 管理器（如 AudioMgr）\n代理 Unity Update 与协程能力"
    note for AudioMgr "【外观模式 Facade】\n音效服务统一入口\n通过 EventCenter 订阅\nAudio_PlayBgm / Audio_PlaySfx\n/ Audio_StopBgm / Audio_SetVolume\n实现事件驱动播音"

    %% Singleton inheritance (Infra)
    BaseMgr <|-- EventCenter
    BaseMgr <|-- ConfigMgr
    BaseMgr <|-- UIMgr
    BaseMgr <|-- PoolMgr
    BaseMgr <|-- ResMgr
    BaseMgr <|-- AudioMgr

    %% EventCenter uses E_EventType as key
    EventCenter --> E_EventType : key

    %% AudioMgr subscribes Audio_* events from EventCenter
    AudioMgr ..> EventCenter : subscribes Audio_PlayBgm\nAudio_PlaySfx\nAudio_StopBgm\nAudio_SetVolume

    %% AudioMgr uses MonoMgr for coroutines (voice release)
    AudioMgr ..> MonoMgr : StartCoroutine

    %% AudioMgr uses PoolMgr to pool AudioSource nodes
    AudioMgr ..> PoolMgr : GetObj/PushObj

    %% AudioMgr uses ResMgr to load AudioRegistry
    AudioMgr ..> ResMgr : Load AudioRegistry

